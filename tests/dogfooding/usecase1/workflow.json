{
  "id": "e2e-test-ekken",
  "name": "E2E Test: Open Credentials and Screenshot",
  "created_by": "system",
  "nodes": [
    {
      "id": "n1",
      "type": "timer",
      "action": {
        "type": "manual",
        "fields": []
      }
    },
    {
      "id": "n2",
      "type": "google_chrome",
      "action": {
        "type": "launch",
        "fields": [
          { "key": "headless", "value": true },
          { "key": "port", "value": 9222 }
        ]
      }
    },
    {
      "id": "n3",
      "type": "chromedp",
      "action": {
        "type": "navigate",
        "fields": [
          { "key": "url", "value": "http://localhost:3033" }
        ]
      }
    },
    {
      "id": "n4",
      "type": "chromedp",
      "action": {
        "type": "click",
        "fields": [
          { "key": "selector", "value": "//span[contains(.,\"Credentials\")]" },
          { "key": "selector_type", "value": "xpath" }
        ]
      }
    },
    {
      "id": "n5",
      "type": "delay",
      "action": {
        "type": "seconds",
        "fields": [
          { "key": "duration", "value": 1.0 }
        ]
      }
    },
    {
      "id": "n6",
      "type": "chromedp",
      "action": {
        "type": "screenshot",
        "fields": [
          { "key": "path", "value": "tests/dogfooding/data/screenshot_credentials.png" },
          { "key": "full_page", "value": true }
        ]
      }
    },
    {
      "id": "n7",
      "type": "google_chrome",
      "action": {
        "type": "terminate",
        "fields": [
          { "key": "port", "value": 9222 }
        ]
      }
    }
  ],
  "edges": [
    {
      "source": "n1",
      "target": "n2",
      "sourceHandle": "success"
    },
    {
      "source": "n2",
      "target": "n3",
      "sourceHandle": "success"
    },
    {
      "source": "n3",
      "target": "n4",
      "sourceHandle": "success"
    },
    {
      "source": "n4",
      "target": "n5",
      "sourceHandle": "success"
    },
    {
      "source": "n5",
      "target": "n6",
      "sourceHandle": "success"
    },
    {
      "source": "n6",
      "target": "n7",
      "sourceHandle": "success"
    }
  ]
}
